{
  "mcpServers": {
    "feedback-angel": {
      "command": "uvx",
      "args": ["feedback-angel@latest"],
      "timeout": 600,
      "env": {
        "MCP_DESKTOP_MODE": "false",
        "MCP_WEB_HOST": "127.0.0.1",
        "MCP_WEB_PORT": "8765",
        "MCP_DEBUG": "false"
      },
      "autoApprove": ["interactive_feedback"]
    },
    "feedback-angel-file-mode": {
      "command": "uvx",
      "args": ["feedback-angel@latest"],
      "timeout": 600,
      "env": {
        "MCP_WEB_HOST": "127.0.0.1",
        "MCP_WEB_PORT": "8765",
        "MCP_IMAGE_DIR": "/tmp/mcp-images",
        "MCP_IMAGE_MODE": "filepath"
      },
      "autoApprove": ["interactive_feedback"]
    }
  }
}
